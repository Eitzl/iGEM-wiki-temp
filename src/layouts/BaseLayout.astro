---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'UCSC iGEM — AMPs: the next wave in antibiotics.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | UCSC iGEM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --blue:       #1295D8;
        --blue-dark:  #0d7ab5;
        --blue-deep:  #0a2a3d;
        --blue-light: #ebf5fc;
        --blue-faint: #f4fafd;
        --gold:       #FFB511;
        --gold-dark:  #d99700;
        --text:       #0f2a3d;
        --text-muted: #5a7a8a;
        --border:     #d0e8f5;
        --nav-height: 60px;
        --radius:     8px;
        --radius-lg:  16px;
        --shadow-sm:  0 2px 8px rgba(18, 149, 216, 0.08);
        --shadow-md:  0 4px 20px rgba(18, 149, 216, 0.12);
        --shadow-lg:  0 8px 40px rgba(18, 149, 216, 0.16);
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        color: var(--text);
        background: #fff;
        padding-top: var(--nav-height);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a { color: var(--blue); text-decoration: none; }
      a:hover { color: var(--blue-dark); }
      img { max-width: 100%; display: block; }

      /* Layout */
      .container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      .section { padding: 5rem 0; }

      /* Typography utilities */
      .section-label {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--gold-dark);
        margin-bottom: 0.6rem;
      }

      .section-title {
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
        margin-bottom: 1rem;
      }

      .section-body {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.75;
        max-width: 660px;
      }

      /* Placeholder blocks */
      .placeholder {
        border: 2px dashed var(--border);
        border-radius: var(--radius);
        padding: 3rem 2rem;
        text-align: center;
        color: var(--text-muted);
        background: var(--blue-faint);
        font-style: italic;
        font-size: 0.9rem;
        line-height: 1.6;
      }

      .placeholder-sm {
        border: 2px dashed var(--border);
        border-radius: var(--radius);
        padding: 1.5rem;
        text-align: center;
        color: var(--text-muted);
        background: var(--blue-faint);
        font-style: italic;
        font-size: 0.85rem;
      }

      /* Buttons */
      .btn {
        display: inline-block;
        padding: 0.75rem 1.75rem;
        border-radius: var(--radius);
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
        border: none;
        font-family: inherit;
        text-decoration: none;
        line-height: 1;
      }

      .btn-primary {
        background: var(--gold);
        color: var(--text);
      }

      .btn-primary:hover {
        background: var(--gold-dark);
        color: var(--text);
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(255, 181, 17, 0.4);
      }

      .btn-outline-white {
        background: transparent;
        color: white;
        border: 2px solid rgba(255, 255, 255, 0.6);
      }

      .btn-outline-white:hover {
        background: white;
        color: var(--blue);
        border-color: white;
        transform: translateY(-2px);
      }

      .btn-blue {
        background: var(--blue);
        color: white;
      }

      .btn-blue:hover {
        background: var(--blue-dark);
        color: white;
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
      }
    </style>
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
