---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';

const breadcrumb = [{ label: 'Project', href: '/project' }];
---
<BaseLayout title="Human Practices" description="Human practices and stakeholder engagement from UCSC iGEM.">

  <PageHeader
    title="Human Practices"
    subtitle="Engaging communities, consulting experts, and ensuring our research is responsible, ethical, and beneficial."
    breadcrumb={breadcrumb}
  />

  <!-- ── OVERVIEW ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Our approach</p>
      <h2 class="section-title">Why Human Practices?</h2>
      <div class="placeholder" style="max-width: 800px; min-height: 140px;">
        Explain your philosophy toward human practices. How did stakeholder feedback shape the direction of your project? Why is this work integral, not supplementary, to your science?
      </div>
    </div>
  </section>

  <!-- ── STAKEHOLDER MAP ────────────────────────────────────── -->
  <section class="section" style="padding-top: 0; background: var(--blue-faint);">
    <div class="container">
      <p class="section-label">Who we talked to</p>
      <h2 class="section-title">Stakeholder Engagement</h2>
      <div class="stakeholder-grid">
        {[
          { icon: '🏥', group: 'Clinicians & Physicians' },
          { icon: '🔬', group: 'Research Scientists' },
          { icon: '🏭', group: 'Industry Partners' },
          { icon: '🧑‍🤝‍🧑', group: 'Patient Communities' },
          { icon: '⚖️', group: 'Policy & Regulatory Experts' },
          { icon: '🎓', group: 'Educators & Students' },
        ].map(s => (
          <div class="stakeholder-card">
            <span class="s-icon">{s.icon}</span>
            <h4>{s.group}</h4>
            <div class="placeholder-sm">Summarize who you spoke with and what you learned.</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── INTERVIEWS / CONSULTATIONS ────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Conversations</p>
      <h2 class="section-title">Key Consultations</h2>
      <div class="consultation-list">
        {Array.from({ length: 3 }).map(() => (
          <div class="consultation-item">
            <div class="consult-meta">
              <div class="placeholder-sm" style="min-width: 180px;">Expert name & affiliation</div>
              <div class="placeholder-sm" style="font-size: 0.8rem; min-width: 100px;">Date</div>
            </div>
            <div class="placeholder" style="min-height: 100px;">
              Summarize the conversation, key takeaways, and how it influenced your project direction.
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── OUTREACH ───────────────────────────────────────────── -->
  <section class="section" style="padding-top: 0; background: var(--blue-faint);">
    <div class="container">
      <p class="section-label">Community impact</p>
      <h2 class="section-title">Outreach & Education</h2>
      <div class="two-col">
        <div class="placeholder" style="min-height: 180px;">
          Describe any public outreach events, school visits, workshops, or science communication efforts your team conducted.
        </div>
        <div class="placeholder" style="min-height: 180px;">[ Photos or summary of outreach activities ]</div>
      </div>
    </div>
  </section>

  <!-- ── IMPACT ON PROJECT ──────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Reflection</p>
      <h2 class="section-title">How HP Shaped Our Science</h2>
      <div class="impact-steps">
        {[
          'We learned that...',
          'This led us to change...',
          'As a result, our project now...',
        ].map((prompt, i) => (
          <div class="impact-step">
            <div class="step-num">{i + 1}</div>
            <div class="placeholder-sm" style="flex: 1;">{prompt} (replace with your reflection)</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .stakeholder-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-top: 2rem;
  }

  .stakeholder-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .s-icon { font-size: 1.75rem; }

  .stakeholder-card h4 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .consultation-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }

  .consultation-item {
    border-left: 4px solid var(--blue);
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .consult-meta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }

  .impact-steps {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2rem;
    max-width: 800px;
  }

  .impact-step {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
  }

  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: var(--blue);
    color: white;
    font-weight: 700;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .two-col { grid-template-columns: 1fr; }
  }
</style>
