---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
---
<BaseLayout title="Project" description="Overview of the UCSC iGEM 2026 project.">

  <PageHeader
    title="Project Overview"
    subtitle="A novel melectin-based antimicrobial peptide for treating Lyme disease — combining scalable synthesis with computational prediction."
  />

  <!-- ── STATUS BANNER ─────────────────────────────────────── -->
  <div class="status-banner">
    <div class="container">
      <span class="status-dot"></span>
      <span>Project status: <strong>Design &amp; planning phase</strong> — actively in development as of 2026.</span>
    </div>
  </div>

  <!-- ── ABSTRACT ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Summary</p>
      <h2 class="section-title">Project Abstract</h2>
      <div class="abstract-body section-body" style="max-width: 820px;">
        <p>
          Our team is developing improved methods for the synthesis of bee venom-derived
          antimicrobial peptides (AMPs), with a focus on melectin as a therapeutic candidate
          against <em>Borrelia burgdorferi</em>, the causative agent of Lyme disease.
          We are building a synthesis and purification workflow that is substantially more
          accessible and cost-effective than existing approaches, while in parallel developing
          computational models to predict AMP behavior directly from protein sequence data.
          By combining scalable synthesis with computational modeling, we aim to improve
          access to affordable and effective AMP-based treatments for patients who may not
          benefit from existing therapies.
        </p>
      </div>
    </div>
  </section>

  <!-- ── PROBLEM STATEMENT ─────────────────────────────────── -->
  <section class="section" style="padding-top: 0; background: var(--blue-faint);">
    <div class="container">
      <p class="section-label">Context</p>
      <h2 class="section-title">The Problem</h2>
      <div class="two-col">
        <div class="problem-text">
          <p class="section-body" style="margin-bottom: 1.25rem;">
            Lyme disease, caused by <em>Borrelia burgdorferi</em>, is the most prevalent
            vector-borne illness in North America, with over <strong>470,000 estimated cases
            annually</strong> in the United States. Despite this burden, treatment options
            remain limited to a small group of oral antibiotics — doxycycline, amoxicillin,
            and cefuroxime — developed decades ago and not specifically optimized for
            <em>Borrelia</em>.
          </p>
          <p class="section-body" style="margin-bottom: 1.25rem;">
            Approximately <strong>10–20% of patients</strong> who receive timely, guideline-adherent
            treatment subsequently develop Post-Treatment Lyme Disease Syndrome (PTLDS),
            characterized by persistent fatigue, cognitive impairment, and musculoskeletal pain.
            A central mechanistic challenge is <em>Borrelia</em>'s ability to transition into
            dormant "persister" cells and biofilm-like aggregates, which display significantly
            reduced susceptibility to conventional antibiotics.
          </p>
          <p class="section-body">
            AMPs primarily disrupt microbial membranes — a mechanism effective across
            various bacterial growth states and less susceptible to resistance development.
            Several AMPs have demonstrated activity against <em>Borrelia</em> persister forms
            in vitro, indicating potential efficacy in patients unresponsive to current
            standard-of-care treatments.
          </p>
        </div>
        <div class="problem-side">
          <div class="highlight-card">
            <div class="highlight-number">470,000</div>
            <p>estimated Lyme cases in the US annually</p>
          </div>
          <div class="highlight-card">
            <div class="highlight-number">10–20%</div>
            <p>of treated patients develop PTLDS</p>
          </div>
          <div class="highlight-card gold-card">
            <p class="highlight-label">Our target</p>
            <p class="highlight-peptide">Melectin</p>
            <p style="font-size: 0.82rem; color: var(--text-muted);">
              An antimicrobial peptide from bee venom with demonstrated activity against
              <em>Borrelia burgdorferi</em>
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── APPROACH ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <p class="section-label">Strategy</p>
      <h2 class="section-title">Our Approach</h2>
      <p class="section-body" style="margin-bottom: 2.5rem;">
        We follow the iGEM design-build-test-learn cycle to iteratively engineer and validate
        our AMP candidates.
      </p>
      <div class="steps">
        {[
          { label: 'Design', desc: 'Identify and computationally evaluate melectin-derived AMP candidates using sequence analysis, structure prediction, and activity modeling pipelines.' },
          { label: 'Build', desc: 'Develop scalable synthesis and purification workflows that are cost-effective and do not require direct bee venom extraction.' },
          { label: 'Test', desc: 'Characterize AMP candidates in vitro against Borrelia burgdorferi, including persister-form assays, MIC testing, and cytotoxicity panels.' },
          { label: 'Learn', desc: 'Feed experimental results back into computational models, refining predictions and guiding the next design iteration.' },
        ].map((step, i) => (
          <div class="step-card">
            <div class="step-num">{i + 1}</div>
            <h3>{step.label}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SUBPAGE CARDS ──────────────────────────────────────── -->
  <section class="section" style="background: var(--blue-faint);">
    <div class="container">
      <p class="section-label">Explore further</p>
      <h2 class="section-title">Dive into the details</h2>
      <div class="cards-grid">
        <a href="/project/wet-lab" class="sub-card">
          <span class="icon">🧪</span>
          <h3>Wet Lab</h3>
          <p>Experimental protocols, synthesis workflows, and characterization results.</p>
        </a>
        <a href="/project/dry-lab" class="sub-card">
          <span class="icon">💻</span>
          <h3>Dry Lab</h3>
          <p>Sequence analysis, structural modeling, and activity prediction pipelines.</p>
        </a>
        <a href="/project/human-practices" class="sub-card">
          <span class="icon">🌍</span>
          <h3>Human Practices</h3>
          <p>Stakeholder engagement, expert consultations, and responsible innovation.</p>
        </a>
        <a href="/project/entrepreneurship" class="sub-card">
          <span class="icon">🚀</span>
          <h3>Entrepreneurship</h3>
          <p>Business model and commercialization strategy for affordable AMP therapeutics.</p>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── Status banner ── */
  .status-banner {
    background: #e8f7ee;
    border-bottom: 1px solid #b2dfc4;
    padding: 0.75rem 0;
    font-size: 0.88rem;
    color: #1a5c32;
  }

  .status-banner .container {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Abstract ── */
  .abstract-body p { line-height: 1.8; color: var(--text-muted); }

  /* ── Two-col ── */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 2rem;
  }

  .problem-text p { margin-bottom: 1rem; }

  .problem-side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .highlight-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--blue);
  }

  .highlight-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--blue);
    line-height: 1.1;
    margin-bottom: 0.3rem;
  }

  .highlight-card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .gold-card {
    border-left-color: var(--gold);
    background: var(--blue-faint);
  }

  .highlight-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold-dark);
    margin-bottom: 0.3rem;
  }

  .highlight-peptide {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text) !important;
    margin-bottom: 0.5rem;
  }

  /* ── Steps ── */
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .step-card {
    border-top: 3px solid var(--gold);
    padding: 1.5rem;
    background: var(--blue-faint);
    border-radius: 0 0 var(--radius) var(--radius);
  }

  .step-num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--blue);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .step-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .step-card p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* ── Sub-cards ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .sub-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    color: var(--text);
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .sub-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    color: var(--text);
  }

  .sub-card .icon { font-size: 1.75rem; margin-bottom: 0.25rem; }

  .sub-card h3 {
    font-size: 1.05rem;
    font-weight: 700;
  }

  .sub-card p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .two-col { grid-template-columns: 1fr; }
  }
</style>
