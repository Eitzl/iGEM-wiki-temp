      </div>
      <nav class="footer-nav">
        <h4>Navigate</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/team">Team</a></li>
          <li><a href="/project">Project</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </nav>
      <nav class="footer-nav">
        <h4>Project</h4>
        <ul>
          <li><a href="/project/wet-lab">Wet Lab</a></li>
          <li><a href="/project/dry-lab">Dry Lab</a></li>
          <li><a href="/project/human-practices">Human Practices</a></li>
          <li><a href="/project/entrepreneurship">Entrepreneurship</a></li>
        </ul>
      </nav>
      <nav class="footer-nav">
        <h4>Info</h4>
        <ul>
          <li><a href="/attribution">Attribution</a></li>
          <li><a href="https://igem.org" target="_blank" rel="noopener">iGEM Foundation ↗</a></li>
