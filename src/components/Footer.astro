  </div>
</footer>

<style>
  footer {
    background: #0a2a3d;
    color: #8db4cc;
    padding: 4rem 0 2rem;
    margin-top: auto;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .brand {
    display: block;
    font-size: 1.3rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.9rem;
    letter-spacing: 0.02em;
  }

  .gold { color: #FFB511; }

  .footer-brand p {
    font-size: 0.88rem;
    line-height: 1.7;
    max-width: 240px;
  }

  .footer-nav h4 {
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.1rem;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-nav a {
    color: #8db4cc;
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-nav a:hover { color: #FFB511; }

  .footer-bottom {
    padding-top: 1.75rem;
    font-size: 0.8rem;
    color: #4d7a96;
  }

  .footer-bottom a {
    color: #6aa0bc;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .footer-bottom a:hover { color: #FFB511; }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
